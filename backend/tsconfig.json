{
  "compilerOptions": {
    /* Environment & Language Features */
    "target": "ESNext",
    "lib": ["ESNext"],
    "module": "ESNext",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,

    /* Bundler & Runtime Behavior (Optimized for Bun) */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "esModuleInterop": true, // Required for bcryptjs/jsonwebtoken imports
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Strictness & Best Practices */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noUncheckedIndexedAccess": true, // Great for financial apps (handling undefined array elements)
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    /* Development Experience */
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    
    /* Path Mapping (Optional - helps with clean imports) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}